{
  "name": "@gabrielassisxyz/opencode-hooks",
  "version": "2026.3.29",
  "description": "OpenCode plugin for running command, tool, and bash hooks from hooks.yaml during session and tool lifecycle events.",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun --format esm && tsc -p tsconfig.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "hooks",
    "automation",
    "workflow",
    "tooling",
    "plugin",
    "runtime"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielassisxyz/opencode-hooks.git"
  },
  "homepage": "https://github.com/gabrielassisxyz/opencode-hooks#readme",
  "bugs": {
    "url": "https://github.com/gabrielassisxyz/opencode-hooks/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "bun-types": "latest",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
